# ---------------------------------------------------------------------------
# 本地/进程环境变量（勿提交；已在 .gitignore）
# ---------------------------------------------------------------------------
# 【推荐】只改这一行即可切换 hailiao-api / hailiao-admin 共用环境：
#   dev（默认）| test | prod
APP_ENV=dev
# 与 APP_ENV 等价，未设置 APP_ENV 时生效：
# SPRING_PROFILES_ACTIVE=dev

# ----------- 仅在 prod 下必须（dev/test 已写在 application-*.yml 中）-----------
# DB_URL=jdbc:mysql://...
# DB_USERNAME=
# DB_PASSWORD=
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# REDIS_TIMEOUT=6000ms
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=
# OSS_DOMAIN=
# OSS_PREFIX=hailiao
# SERVER_PORT=8082
# ADMIN_SERVER_PORT=8083

# 若 dev 要使用真实 OSS，可在本文件取消注释并填写（或改 application-dev.yml）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
